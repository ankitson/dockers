@@ -0,0 +1,24 @@
+package modelcatalog
+
+import (
+	"testing"
+
+	"github.com/maximhq/bifrost/core/schemas"
+	"github.com/maximhq/bifrost/framework/configstore"
+)
+
+func TestCustomProviderWildcardAllowsUnlistedAlias(t *testing.T) {
+	catalog := NewTestCatalog(nil)
+	provider := schemas.ModelProvider("lmstudio")
+	catalog.UpsertLive(provider, "lmstudio-key", false, []string{"lmstudio/gemma-listed"})
+	providerConfig := &configstore.ProviderConfig{
+		CustomProviderConfig: &schemas.CustomProviderConfig{},
+	}
+
+	if !providerConfig.CustomProviderConfig.IsOperationAllowed(schemas.ListModelsRequest) {
+		t.Fatal("test requires list-models to be enabled")
+	}
+	if !catalog.IsModelAllowedForProvider(provider, "current", providerConfig, schemas.WhiteList{"*"}) {
+		t.Fatal("wildcard VK policy blocked a callable custom-provider alias absent from /v1/models")
+	}
+}
