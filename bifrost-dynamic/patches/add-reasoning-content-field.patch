diff --git a/core/schemas/reasoningcontent_test.go b/core/schemas/reasoningcontent_test.go
new file mode 100644
index 0000000..a9cdc4a
--- /dev/null
+++ b/core/schemas/reasoningcontent_test.go
@@ -0,0 +1,58 @@
+package schemas
+
+import (
+	"encoding/json"
+	"testing"
+)
+
+func TestReasoningContentRoundTrip(t *testing.T) {
+	tests := []struct {
+		name      string
+		unmarshal func([]byte) (reasoning, reasoningContent *string, encoded []byte, err error)
+	}{
+		{
+			name: "assistant message",
+			unmarshal: func(data []byte) (*string, *string, []byte, error) {
+				var value ChatAssistantMessage
+				if err := json.Unmarshal(data, &value); err != nil {
+					return nil, nil, nil, err
+				}
+				encoded, err := json.Marshal(value)
+				return value.Reasoning, value.ReasoningContent, encoded, err
+			},
+		},
+		{
+			name: "stream delta",
+			unmarshal: func(data []byte) (*string, *string, []byte, error) {
+				var value ChatStreamResponseChoiceDelta
+				if err := json.Unmarshal(data, &value); err != nil {
+					return nil, nil, nil, err
+				}
+				encoded, err := json.Marshal(value)
+				return value.Reasoning, value.ReasoningContent, encoded, err
+			},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			reasoning, reasoningContent, encoded, err := tt.unmarshal([]byte(`{"reasoning_content":"thinking"}`))
+			if err != nil {
+				t.Fatal(err)
+			}
+			if reasoning == nil || *reasoning != "thinking" {
+				t.Fatalf("reasoning = %v, want thinking", reasoning)
+			}
+			if reasoningContent == nil || *reasoningContent != "thinking" {
+				t.Fatalf("reasoning_content = %v, want thinking", reasoningContent)
+			}
+			var payload map[string]any
+			if err := json.Unmarshal(encoded, &payload); err != nil {
+				t.Fatal(err)
+			}
+			if payload["reasoning_content"] != "thinking" {
+				t.Fatalf("encoded reasoning_content = %v, want thinking", payload["reasoning_content"])
+			}
+		})
+	}
+}
