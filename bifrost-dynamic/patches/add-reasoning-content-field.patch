index 0000000..861b9d9
--- /dev/null
+++ b/framework/streaming/reasoningcontent_test.go
@@ -0,0 +1,20 @@
+package streaming
+
+import (
+	"testing"
+
+	"github.com/maximhq/bifrost/core/schemas"
+)
+
+func TestDeepCopyChatStreamDeltaCopiesReasoningContent(t *testing.T) {
+	value := "thinking"
+	original := &schemas.ChatStreamResponseChoiceDelta{ReasoningContent: &value}
+	copied := deepCopyChatStreamDelta(original)
+
+	if copied.ReasoningContent == nil || *copied.ReasoningContent != value {
+		t.Fatalf("copied reasoning_content = %v, want %q", copied.ReasoningContent, value)
+	}
+	if copied.ReasoningContent == original.ReasoningContent {
+		t.Fatal("reasoning_content pointer was not deep-copied")
+	}
+}
