+func TestDropUnsupportedParams_CustomProviderPreservesResponsesHostedTools(t *testing.T) {
+	newRequest := func() *schemas.BifrostRequest {
+		return newResponsesRequest(schemas.OpenAI, "gpt-5.4-mini", &schemas.ResponsesParameters{
+			Tools: []schemas.ResponsesTool{
+				{Type: schemas.ResponsesToolTypeFunction},
+				{Type: schemas.ResponsesToolTypeWebSearch},
+				{Type: schemas.ResponsesToolTypeWebSearchPreview},
+			},
+		})
+	}
+
+	customReq := newRequest()
+	customCtx := newTestContext()
+	customCtx.SetValue(schemas.BifrostContextKeyIsCustomProvider, true)
+	customDropped := dropUnsupportedParams(customCtx, customReq, []string{"tools"})
+	if got := len(customReq.ResponsesRequest.Params.Tools); got != 3 {
+		t.Fatalf("custom provider tools = %d, want all 3 preserved", got)
+	}
+	for _, unexpected := range []string{"tools[1].web_search", "tools[2].web_search_preview"} {
+		if slices.Contains(customDropped, unexpected) {
+			t.Errorf("custom provider reported %q in dropped=%v", unexpected, customDropped)
+		}
+	}
+
+	standardReq := newRequest()
+	standardDropped := dropUnsupportedParams(newTestContext(), standardReq, []string{"tools"})
+	tools := standardReq.ResponsesRequest.Params.Tools
+	if got := len(tools); got != 1 || tools[0].Type != schemas.ResponsesToolTypeFunction {
+		t.Fatalf("standard provider tools = %+v, want only function tool", tools)
+	}
+	for _, expected := range []string{"tools[1].web_search", "tools[2].web_search_preview"} {
+		if !slices.Contains(standardDropped, expected) {
+			t.Errorf("standard provider missing %q in dropped=%v", expected, standardDropped)
+		}
+	}
+}
