-		if !isSupported["web_search"] {
+		// A custom OpenAI-compatible provider can support hosted tools that are
+		// absent from the public model catalog. The catalog is authoritative for
+		// standard providers, but must not strip those provider-native tools from
+		// a custom endpoint before it has a chance to handle them.
+		isCustomProvider, _ := ctx.Value(schemas.BifrostContextKeyIsCustomProvider).(bool)
+		if !isSupported["web_search"] && !isCustomProvider {
